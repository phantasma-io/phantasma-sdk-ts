{
  "name": "phantasma-sdk-ts",
  "version": "0.8.0",
  "description": "Typescript SDK for interacting with the Phantasma Chain",
  "author": "Phantasma Team",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./public": {
      "types": "./dist/types/public.d.ts",
      "import": "./dist/esm/public.js",
      "require": "./dist/cjs/public.js"
    },
    "./interfaces": {
      "types": "./dist/types/interfaces/index.d.ts",
      "import": "./dist/esm/interfaces/index.js",
      "require": "./dist/cjs/interfaces/index.js"
    },
    "./ledger": {
      "types": "./dist/types/ledger/index.d.ts",
      "import": "./dist/esm/ledger/index.js",
      "require": "./dist/cjs/ledger/index.js"
    },
    "./link": {
      "types": "./dist/types/link/index.d.ts",
      "import": "./dist/esm/link/index.js",
      "require": "./dist/cjs/link/index.js"
    },
    "./rpc": {
      "types": "./dist/types/rpc/index.d.ts",
      "import": "./dist/esm/rpc/index.js",
      "require": "./dist/cjs/rpc/index.js"
    },
    "./tx": {
      "types": "./dist/types/tx/index.d.ts",
      "import": "./dist/esm/tx/index.js",
      "require": "./dist/cjs/tx/index.js"
    },
    "./types": {
      "types": "./dist/types/types/index.d.ts",
      "import": "./dist/esm/types/index.js",
      "require": "./dist/cjs/types/index.js"
    },
    "./utils": {
      "types": "./dist/types/utils/index.d.ts",
      "import": "./dist/esm/utils/index.js",
      "require": "./dist/cjs/utils/index.js"
    },
    "./vm": {
      "types": "./dist/types/vm/index.d.ts",
      "import": "./dist/esm/vm/index.js",
      "require": "./dist/cjs/vm/index.js"
    },
    "./core": {
      "types": "./dist/types/core/index.d.ts",
      "import": "./dist/esm/core/index.js",
      "require": "./dist/cjs/core/index.js"
    },
    "./core/interfaces": {
      "types": "./dist/types/core/interfaces/index.d.ts",
      "import": "./dist/esm/core/interfaces/index.js",
      "require": "./dist/cjs/core/interfaces/index.js"
    },
    "./core/ledger": {
      "types": "./dist/types/core/ledger/index.d.ts",
      "import": "./dist/esm/core/ledger/index.js",
      "require": "./dist/cjs/core/ledger/index.js"
    },
    "./core/link": {
      "types": "./dist/types/core/link/index.d.ts",
      "import": "./dist/esm/core/link/index.js",
      "require": "./dist/cjs/core/link/index.js"
    },
    "./core/rpc": {
      "types": "./dist/types/core/rpc/index.d.ts",
      "import": "./dist/esm/core/rpc/index.js",
      "require": "./dist/cjs/core/rpc/index.js"
    },
    "./core/tx": {
      "types": "./dist/types/core/tx/index.d.ts",
      "import": "./dist/esm/core/tx/index.js",
      "require": "./dist/cjs/core/tx/index.js"
    },
    "./core/types": {
      "types": "./dist/types/core/types/index.d.ts",
      "import": "./dist/esm/core/types/index.js",
      "require": "./dist/cjs/core/types/index.js"
    },
    "./core/utils": {
      "types": "./dist/types/core/utils/index.d.ts",
      "import": "./dist/esm/core/utils/index.js",
      "require": "./dist/cjs/core/utils/index.js"
    },
    "./core/vm": {
      "types": "./dist/types/core/vm/index.d.ts",
      "import": "./dist/esm/core/vm/index.js",
      "require": "./dist/cjs/core/vm/index.js"
    },
    "./interfaces/*": {
      "types": "./dist/types/interfaces/*.d.ts",
      "import": "./dist/esm/interfaces/*.js",
      "require": "./dist/cjs/interfaces/*.js"
    },
    "./ledger/*": {
      "types": "./dist/types/ledger/*.d.ts",
      "import": "./dist/esm/ledger/*.js",
      "require": "./dist/cjs/ledger/*.js"
    },
    "./link/*": {
      "types": "./dist/types/link/*.d.ts",
      "import": "./dist/esm/link/*.js",
      "require": "./dist/cjs/link/*.js"
    },
    "./rpc/*": {
      "types": "./dist/types/rpc/*.d.ts",
      "import": "./dist/esm/rpc/*.js",
      "require": "./dist/cjs/rpc/*.js"
    },
    "./tx/*": {
      "types": "./dist/types/tx/*.d.ts",
      "import": "./dist/esm/tx/*.js",
      "require": "./dist/cjs/tx/*.js"
    },
    "./types/*": {
      "types": "./dist/types/types/*.d.ts",
      "import": "./dist/esm/types/*.js",
      "require": "./dist/cjs/types/*.js"
    },
    "./utils/*": {
      "types": "./dist/types/utils/*.d.ts",
      "import": "./dist/esm/utils/*.js",
      "require": "./dist/cjs/utils/*.js"
    },
    "./vm/*": {
      "types": "./dist/types/vm/*.d.ts",
      "import": "./dist/esm/vm/*.js",
      "require": "./dist/cjs/vm/*.js"
    },
    "./core/*": {
      "types": "./dist/types/core/*.d.ts",
      "import": "./dist/esm/core/*.js",
      "require": "./dist/cjs/core/*.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "public": [
        "dist/types/public.d.ts"
      ],
      "interfaces": [
        "dist/types/interfaces/index.d.ts"
      ],
      "ledger": [
        "dist/types/ledger/index.d.ts"
      ],
      "link": [
        "dist/types/link/index.d.ts"
      ],
      "rpc": [
        "dist/types/rpc/index.d.ts"
      ],
      "tx": [
        "dist/types/tx/index.d.ts"
      ],
      "types": [
        "dist/types/types/index.d.ts"
      ],
      "utils": [
        "dist/types/utils/index.d.ts"
      ],
      "vm": [
        "dist/types/vm/index.d.ts"
      ],
      "core": [
        "dist/types/core/index.d.ts"
      ],
      "core/interfaces": [
        "dist/types/core/interfaces/index.d.ts"
      ],
      "core/ledger": [
        "dist/types/core/ledger/index.d.ts"
      ],
      "core/link": [
        "dist/types/core/link/index.d.ts"
      ],
      "core/rpc": [
        "dist/types/core/rpc/index.d.ts"
      ],
      "core/tx": [
        "dist/types/core/tx/index.d.ts"
      ],
      "core/types": [
        "dist/types/core/types/index.d.ts"
      ],
      "core/utils": [
        "dist/types/core/utils/index.d.ts"
      ],
      "core/vm": [
        "dist/types/core/vm/index.d.ts"
      ],
      "interfaces/*": [
        "dist/types/interfaces/*"
      ],
      "ledger/*": [
        "dist/types/ledger/*"
      ],
      "link/*": [
        "dist/types/link/*"
      ],
      "rpc/*": [
        "dist/types/rpc/*"
      ],
      "tx/*": [
        "dist/types/tx/*"
      ],
      "types/*": [
        "dist/types/types/*"
      ],
      "utils/*": [
        "dist/types/utils/*"
      ],
      "vm/*": [
        "dist/types/vm/*"
      ],
      "core/*": [
        "dist/types/core/*"
      ]
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run clean && npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json && node -e \"const fs=require('fs'); const path=require('path'); const out=path.join('dist','esm','package.json'); fs.writeFileSync(out, '{\\\"type\\\":\\\"module\\\"}\\n');\"",
    "build:umd": "npm run build:cjs && browserify dist/cjs/index.js -s phantasma > html/phantasma.js",
    "clean": "node scripts/clean-dist.mjs",
    "test": "npm run test:cjs && npm run test:esm && npm run test:package-exports",
    "tests": "npm run test",
    "test:cjs": "jest --config jest.config.js --runInBand",
    "test:esm": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.esm.cjs --runInBand",
    "test:esm-runtime": "npm run test:package-exports",
    "test:package-exports": "npm run build && node scripts/check-package-exports.mjs && node scripts/check-public-types.mjs && node scripts/check-examples.mjs",
    "coverage": "jest --coverage",
    "typecheck": "tsc -p tsconfig.json --pretty false",
    "lint": "npm run typecheck && node scripts/check-deprecated-api-usage.mjs && node scripts/check-consumer-deprecated-api.mjs && node scripts/check-compat-shims.mjs && node scripts/check-source-filenames.mjs && prettier --check . && eslint .",
    "format": "prettier --write .",
    "prettier-watch": "onchange 'src/**/*.ts' -- prettier --write {{changed}}"
  },
  "files": [
    "dist/**/*",
    "examples/**/*",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phantasma-io/phantasma-sdk-ts.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/phantasma-io/phantasma-sdk-ts/issues"
  },
  "homepage": "https://github.com/phantasma-io/phantasma-sdk-ts#readme",
  "dependencies": {
    "@ledgerhq/hw-transport-node-hid": "^6.33.2",
    "@ledgerhq/hw-transport-webusb": "^6.34.2",
    "big-integer": "^1.6.52",
    "bip32": "^5.0.1",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "cross-fetch": "^4.1.0",
    "crypto-js": "^4.2.0",
    "csharp-binary-stream": "^2.0.0",
    "tiny-secp256k1": "^2.2.4",
    "tweetnacl": "^1.0.3",
    "wif": "^5.0.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "browserify": "^17.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
